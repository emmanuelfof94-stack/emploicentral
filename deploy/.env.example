# Modèle d'environnement de déploiement. Copier en `.env` puis remplir.
#   cp .env.example .env
# Générer des secrets forts :
#   python3 -c "import secrets; print(secrets.token_hex(32))"   # JWT_SECRET_KEY
#   python3 -c "import secrets; print(secrets.token_hex(16))"   # MASK_KEY

DOMAIN=topjob.exemple.com
TLS_EMAIL=toi@exemple.com

DEBUG=false
ENVIRONMENT=prod
HOST=0.0.0.0
PORT=8000
FRONTEND_URL=https://topjob.exemple.com

DATABASE_URL=sqlite+aiosqlite:////data/app.db

JWT_SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
MASK_KEY=CHANGE_ME

OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPE="openid profile email"
APP_AI_BASE_URL=
APP_AI_KEY=
OSS_SERVICE_URL=
OSS_API_KEY=
STRIPE_SECRET_KEY=
ADMIN_USER_ID=
ADMIN_USER_EMAIL=

AGGREGATOR_ENABLED=true
AGGREGATOR_INTERVAL_MINUTES=360
AGGREGATOR_PAGES=4
AGGREGATOR_MAX_PER_RUN=40
AGGREGATOR_RUN_ON_STARTUP=true
